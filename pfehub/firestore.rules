rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read all users (for admin assignment)
      allow read: if isAuthenticated();
      // Users can only write their own profile; admins can write any
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      // Students can read projects they are assigned to; admins read all
      allow read: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid in resource.data.students
      );
      allow create, update, delete: if isAdmin();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Labs ──────────────────────────────────────────────────────────────────
    match /labs/{labId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Resources ─────────────────────────────────────────────────────────────
    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Submissions ───────────────────────────────────────────────────────────
    match /submissions/{submissionId} {
      // Admin reads all; students read only their own
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.studentId == request.auth.uid
      );
      // Students create their own submissions
      allow create: if isAuthenticated() &&
        request.resource.data.studentId == request.auth.uid;
      // Only admins can grade (update grade/feedback fields)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      // Admins can create notifications for anyone
      allow create: if isAdmin() || isAuthenticated();
      // Users can mark their own as read
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }
  }
}
